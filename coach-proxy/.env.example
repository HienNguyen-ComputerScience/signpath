# SignPath Coach Proxy — environment template
#
# Copy this to `.env` and set real values (DO NOT commit .env).
# This file does NOT load automatically — export these or use a process
# manager that injects them (systemd EnvironmentFile, pm2 ecosystem,
# docker-compose env_file, etc.).

# Required: your Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# Optional: which Gemini model to use. Default: gemini-2.5-flash.
# Free tier in 2026 gives ~1500 req/day on flash.
GEMINI_MODEL=gemini-2.5-flash

# Optional: port. Default 8787.
PORT=8787

# Optional: comma-separated CORS allowlist. Browser origins calling /coach
# must match one of these. Default: http://localhost:8000.
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5173
